SECRET_KEY=put-a-long-random-string-here
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTH_COOKIE_ACCESS=mm_access
AUTH_COOKIE_REFRESH=mm_refresh
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
VERIFY_CODE_EXPIRE_MINUTES=10

MAIL_TRANSPORT=console
MAIL_FROM=no-reply@localhost
ENV=prod
SECRET_KEY=some-very-long-random-string
CORS_ORIGINS=https://medimind.com
DATABASE_URL=sqlite:///./medimind.db
AUTH_COOKIE_ACCESS=mm_access
AUTH_COOKIE_REFRESH=mm_refresh
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
VERIFY_CODE_EXPIRE_MINUTES=10

MAIL_TRANSPORT=smtp
MAIL_FROM=no-reply@yourdomain.com
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
